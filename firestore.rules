rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // TEMPORARY: open access so the app works without a login screen.
    // Anyone with your Firestore URL could read/write your tasks like this.
    // See SETUP.md "Security" section before you rely on this long-term.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
